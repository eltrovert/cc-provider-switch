#!/usr/bin/env bash
# cc-provider-switch - Switch Claude Code API providers
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PROVIDERS_DIR="$SCRIPT_DIR/providers"
CONFIG_FILE="$SCRIPT_DIR/config.json"

# Default target: global settings
SETTINGS_FILE="$HOME/.claude/settings.json"
BACKUP_FILE="$HOME/.claude/settings.json.bak"
PROJECT_PATH=""

# Parse --project / -p flag
parse_project_flag() {
    local args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -p|--project)
                if [[ -z "${2:-}" ]]; then
                    echo -e "${RED}Error: --project requires a path${NC}"
                    exit 1
                fi
                PROJECT_PATH="$2"
                shift 2
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done
    REMAINING_ARGS=("${args[@]+"${args[@]}"}")

    if [[ -n "$PROJECT_PATH" ]]; then
        # If path points to a file, use it directly
        if [[ -f "$PROJECT_PATH" && "$PROJECT_PATH" == *.json ]]; then
            SETTINGS_FILE="$PROJECT_PATH"
        else
            # Treat as project directory
            PROJECT_PATH="${PROJECT_PATH%/}"
            SETTINGS_FILE="$PROJECT_PATH/.claude/settings.local.json"
        fi
        BACKUP_FILE="${SETTINGS_FILE}.bak"

        # Create the file if it doesn't exist
        if [[ ! -f "$SETTINGS_FILE" ]]; then
            mkdir -p "$(dirname "$SETTINGS_FILE")"
            echo '{}' > "$SETTINGS_FILE"
        fi
    fi
}

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Ensure config file exists
init_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo '{"active_provider": "anthropic"}' > "$CONFIG_FILE"
    fi
}

get_current_provider() {
    jq -r '.active_provider // "anthropic"' "$CONFIG_FILE"
}

list_providers() {
    echo -e "${BLUE}Available providers:${NC}"
    echo
    for file in "$PROVIDERS_DIR"/*.json; do
        if [[ -f "$file" ]]; then
            local name=$(jq -r '.name' "$file")
            local desc=$(jq -r '.description // "No description"' "$file")
            local current=""
            if [[ "$(get_current_provider)" == "$name" ]]; then
                current=" (active)"
            fi
            printf "  ${YELLOW}%-12s${NC} %s%s\n" "$name" "$desc" "$current"
        fi
    done
    echo
}

find_provider_file() {
    local target="$1"
    local provider_file="$PROVIDERS_DIR/${target}.json"

    # Try direct filename match
    if [[ -f "$provider_file" ]]; then
        echo "$provider_file"
        return 0
    fi

    # Try matching by name field in JSON
    for file in "$PROVIDERS_DIR"/*.json; do
        if [[ -f "$file" ]]; then
            local name=$(jq -r '.name' "$file")
            if [[ "$name" == "$target" ]]; then
                echo "$file"
                return 0
            fi
        fi
    done

    return 1
}

show_status() {
    local current=$(get_current_provider)
    local provider_file=$(find_provider_file "$current")

    if [[ -n "$provider_file" && -f "$provider_file" ]]; then
        local name=$(jq -r '.name' "$provider_file")
        local desc=$(jq -r '.description' "$provider_file")
        local target_label="global"
        if [[ -n "$PROJECT_PATH" ]]; then
            target_label="$SETTINGS_FILE"
        fi
        echo -e "${GREEN}Active provider:${NC} $name ($desc) [${target_label}]"
        echo -e "${BLUE}Environment:${NC}"
        jq -r '.env | to_entries[] | "  \(.key)=\(.value)"' "$provider_file"
    else
        echo -e "${RED}Unknown provider: $current${NC}"
    fi
}

switch_provider() {
    local target="$1"
    local provider_file="$PROVIDERS_DIR/${target}.json"

    # Try direct filename match first
    if [[ ! -f "$provider_file" ]]; then
        # Try matching by name field in JSON
        for file in "$PROVIDERS_DIR"/*.json; do
            if [[ -f "$file" ]]; then
                local name=$(jq -r '.name' "$file")
                if [[ "$name" == "$target" ]]; then
                    provider_file="$file"
                    break
                fi
            fi
        done
    fi

    if [[ ! -f "$provider_file" ]]; then
        echo -e "${RED}Error: Provider '$target' not found${NC}"
        echo "Available providers:"
        for file in "$PROVIDERS_DIR"/*.json; do
            [[ -f "$file" ]] && jq -r '.name' "$file"
        done
        exit 1
    fi

    # Backup current settings
    cp "$SETTINGS_FILE" "$BACKUP_FILE"

    # Collect ALL env keys used by ANY provider (these are "managed" keys)
    local all_keys=$(jq -s '[.[].env | keys[]] | unique' "$PROVIDERS_DIR"/*.json)

    # Read new provider env
    local provider_env=$(jq -c '.env' "$provider_file")

    # Read provider-level settings overrides (e.g. model)
    local provider_settings=$(jq -c '.settings // {}' "$provider_file")

    # Collect ALL settings keys used by ANY provider (these are "managed" keys)
    local all_settings_keys=$(jq -s '[.[].settings // {} | keys[]] | unique' "$PROVIDERS_DIR"/*.json)

    # Remove all provider-managed keys from settings.json, then apply new provider's env and settings
    local merged=$(jq --argjson remove_keys "$all_keys" --argjson new_env "$provider_env" \
        --argjson remove_settings_keys "$all_settings_keys" --argjson new_settings "$provider_settings" '
        (.env |= (reduce $remove_keys[] as $k (.; del(.[$k]))) + $new_env) |
        (reduce $remove_settings_keys[] as $k (.; del(.[$k]))) + $new_settings
    ' "$SETTINGS_FILE")
    echo "$merged" > "$SETTINGS_FILE"

    # Update config
    local name=$(jq -r '.name' "$provider_file")
    jq --arg provider "$name" '.active_provider = $provider' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp"
    mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"

    local target_label="global"
    if [[ -n "$PROJECT_PATH" ]]; then
        target_label="$SETTINGS_FILE"
    fi
    echo -e "${GREEN}✓ Switched to $name${NC} (${target_label})"
}

interactive_menu() {
    local providers=()
    local names=()

    for file in "$PROVIDERS_DIR"/*.json; do
        if [[ -f "$file" ]]; then
            providers+=("$file")
            names+=("$(jq -r '.name' "$file")")
        fi
    done

    if [[ ${#providers[@]} -eq 0 ]]; then
        echo -e "${RED}No providers found${NC}"
        exit 1
    fi

    echo -e "${BLUE}Select provider:${NC}"
    echo

    local current=$(get_current_provider)
    for i in "${!names[@]}"; do
        local marker=""
        if [[ "${names[$i]}" == "$current" ]]; then
            marker=" ${GREEN}✓${NC}"
        fi
        printf "  ${YELLOW}%2d${NC}) %s%s\n" "$((i+1))" "${names[$i]}" "$marker"
    done
    echo

    read -p "Enter choice [1-${#names[@]}]: " choice

    if [[ "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 ]] && [[ "$choice" -le ${#names[@]} ]]; then
        switch_provider "${names[$((choice-1))]}"
    else
        echo -e "${RED}Invalid choice${NC}"
        exit 1
    fi
}

show_help() {
    echo "cc-provider-switch - Switch Claude Code API providers"
    echo
    echo "Usage:"
    echo "  cc-switch              Interactive menu"
    echo "  cc-switch <provider>   Switch to specific provider"
    echo "  cc-switch status       Show current provider"
    echo "  cc-switch list         List all providers"
    echo "  cc-switch help         Show this help"
    echo
    echo "Options:"
    echo "  -p, --project <path>   Target a project's settings.local.json"
    echo "                         Path can be a project dir or a .json file"
    echo
    echo "Examples:"
    echo "  cc-switch -p ~/myproject ollama    Switch myproject to ollama"
    echo "  cc-switch -p ~/myproject status    Show myproject's active provider"
    echo
    echo "Providers:"
    for file in "$PROVIDERS_DIR"/*.json; do
        if [[ -f "$file" ]]; then
            printf "  %-12s %s\n" "$(jq -r '.name' "$file")" "$(jq -r '.description' "$file")"
        fi
    done
}

# Main
parse_project_flag "$@"
init_config

case "${REMAINING_ARGS[0]:-}" in
    "")
        interactive_menu
        ;;
    status|s|--status|-c)
        show_status
        ;;
    list|ls|--list|-l)
        list_providers
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        switch_provider "${REMAINING_ARGS[0]}"
        ;;
esac
