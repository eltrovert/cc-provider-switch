#!/usr/bin/env bash
# cc-provider-switch - Switch Claude Code API providers
set -euo pipefail

VERSION="1.0.0"

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PROVIDERS_DIR="${CC_PROVIDERS_DIR:-$SCRIPT_DIR/providers}"
CONFIG_FILE="${CC_CONFIG_FILE:-$SCRIPT_DIR/config.json}"

SETTINGS_FILE="${CC_SETTINGS_FILE:-$HOME/.claude/settings.json}"
BACKUP_FILE=""
PROJECT_PATH=""
COMMAND=""
COMMAND_ARG=""

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# --- Config ---

init_config() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        echo '{"active_provider": "anthropic"}' > "$CONFIG_FILE"
    fi
}

get_current_provider() {
    jq -r '.active_provider // "anthropic"' "$CONFIG_FILE"
}

# --- Validation ---

validate_provider_file() {
    local file="$1"
    local errors=0

    if ! jq empty "$file" 2>/dev/null; then
        echo -e "  ${RED}Invalid JSON${NC}"
        return 1
    fi

    local name=$(jq -r '.name // ""' "$file")
    if [[ -z "$name" || "$name" == "null" ]]; then
        echo -e "  ${RED}Missing 'name' field${NC}"
        errors=$((errors + 1))
    fi

    local env_keys=$(jq -r '.env | keys | length' "$file")
    if [[ "$env_keys" == "0" ]]; then
        echo -e "  ${RED}Missing or empty 'env' object${NC}"
        errors=$((errors + 1))
    fi

    return $errors
}

validate_all_providers() {
    local has_errors=0
    for file in "$PROVIDERS_DIR"/*.json; do
        if [[ -f "$file" ]]; then
            local name=$(jq -r '.name' "$file")
            printf "  %-15s " "$name"
            if validate_provider_file "$file"; then
                echo -e "${GREEN}ok${NC}"
            else
                has_errors=1
            fi
        fi
    done
    return $has_errors
}

# --- Provider lookup ---

find_provider_file() {
    local target="$1"
    local provider_file="$PROVIDERS_DIR/${target}.json"

    if [[ -f "$provider_file" ]]; then
        echo "$provider_file"
        return 0
    fi

    for file in "$PROVIDERS_DIR"/*.json; do
        if [[ -f "$file" ]]; then
            local name=$(jq -r '.name' "$file")
            if [[ "$name" == "$target" ]]; then
                echo "$file"
                return 0
            fi
        fi
    done

    return 1
}

# --- Display ---

list_providers() {
    echo -e "${BLUE}Available providers:${NC}"
    echo
    for file in "$PROVIDERS_DIR"/*.json; do
        if [[ -f "$file" ]]; then
            local name=$(jq -r '.name' "$file")
            local desc=$(jq -r '.description // "No description"' "$file")
            local current=""
            if [[ "$(get_current_provider)" == "$name" ]]; then
                current=" ${GREEN}(active)${NC}"
            fi
            printf "  ${YELLOW}%-12s${NC} %s%s\n" "$name" "$desc" "$current"
        fi
    done
    echo
}

show_status() {
    local current=$(get_current_provider)
    local provider_file=$(find_provider_file "$current")

    if [[ -n "$provider_file" && -f "$provider_file" ]]; then
        local name=$(jq -r '.name' "$provider_file")
        local desc=$(jq -r '.description' "$provider_file")
        local target_label="global"
        if [[ -n "$PROJECT_PATH" ]]; then
            target_label="$SETTINGS_FILE"
        fi
        echo -e "${GREEN}Active provider:${NC} $name ($desc) [${target_label}]"
        echo -e "${BLUE}Environment:${NC}"
        jq -r '.env | to_entries[] | "  \(.key)=\(.value)"' "$provider_file"
    else
        echo -e "${RED}Unknown provider: $current${NC}"
    fi
}

# --- Health check ---

check_provider() {
    local target="$1"
    local provider_file=$(find_provider_file "$target")

    if [[ -z "$provider_file" || ! -f "$provider_file" ]]; then
        echo -e "${RED}Provider '$target' not found${NC}"
        return 1
    fi

    local base_url=$(jq -r '.env.ANTHROPIC_BASE_URL // empty' "$provider_file")
    if [[ -z "$base_url" ]]; then
        echo -e "${YELLOW}$target: No ANTHROPIC_BASE_URL defined, skipping${NC}"
        return 0
    fi

    if ! command -v curl &>/dev/null; then
        echo -e "${YELLOW}$target: curl not available, skipping${NC}"
        return 0
    fi

    local name=$(jq -r '.name' "$provider_file")
    printf "  %-12s " "$name"
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 5 "$base_url" 2>/dev/null) || true

    if [[ "$code" == "000" ]]; then
        echo -e "${RED}unreachable${NC}"
        return 1
    elif [[ "$code" =~ ^2 ]]; then
        echo -e "${GREEN}reachable (HTTP $code)${NC}"
        return 0
    else
        echo -e "${YELLOW}degraded (HTTP $code)${NC}"
        return 0
    fi
}

check_all_providers() {
    local failures=0
    for file in "$PROVIDERS_DIR"/*.json; do
        if [[ -f "$file" ]]; then
            local name=$(jq -r '.name' "$file")
            check_provider "$name" || failures=$((failures + 1))
        fi
    done
    return $failures
}

# --- Switch ---

switch_provider() {
    local target="$1"
    local provider_file=$(find_provider_file "$target")

    if [[ -z "$provider_file" || ! -f "$provider_file" ]]; then
        echo -e "${RED}Error: Provider '$target' not found${NC}"
        echo "Available providers:"
        for file in "$PROVIDERS_DIR"/*.json; do
            [[ -f "$file" ]] && jq -r '.name' "$file"
        done
        exit 1
    fi

    local name=$(jq -r '.name' "$provider_file")

    if ! validate_provider_file "$provider_file"; then
        echo -e "${RED}Error: Provider '$name' has invalid config${NC}"
        exit 1
    fi

    cp "$SETTINGS_FILE" "$BACKUP_FILE"

    local all_keys=$(jq -s '[.[].env | keys[]] | unique' "$PROVIDERS_DIR"/*.json)
    local provider_env=$(jq -c '.env' "$provider_file")
    local provider_settings=$(jq -c '.settings // {}' "$provider_file")
    local all_settings_keys=$(jq -s '[.[].settings // {} | keys[]] | unique' "$PROVIDERS_DIR"/*.json)

    local merged=$(jq --argjson remove_keys "$all_keys" --argjson new_env "$provider_env" \
        --argjson remove_settings_keys "$all_settings_keys" --argjson new_settings "$provider_settings" '
        (.env |= (reduce $remove_keys[] as $k (.; del(.[$k]))) + $new_env) |
        (reduce $remove_settings_keys[] as $k (.; del(.[$k]))) + $new_settings
    ' "$SETTINGS_FILE")
    echo "$merged" > "$SETTINGS_FILE"

    jq --arg provider "$name" '.active_provider = $provider' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp"
    mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"

    local target_label="global"
    if [[ -n "$PROJECT_PATH" ]]; then
        target_label="$SETTINGS_FILE"
    fi
    echo -e "${GREEN}Switched to $name${NC} (${target_label})"
}

rollback_switch() {
    if [[ ! -f "$BACKUP_FILE" ]]; then
        echo -e "${RED}No backup found at $BACKUP_FILE${NC}"
        exit 1
    fi

    cp "$BACKUP_FILE" "$SETTINGS_FILE"
    local prev_provider=$(jq -r '.active_provider // "unknown"' "$SETTINGS_FILE")
    jq --arg provider "$prev_provider" '.active_provider = $provider' "$CONFIG_FILE" > "${CONFIG_FILE}.tmp"
    mv "${CONFIG_FILE}.tmp" "$CONFIG_FILE"

    echo -e "${GREEN}Rolled back to $prev_provider${NC}"
}

# --- Interactive ---

interactive_menu() {
    local providers=()
    local names=()

    for file in "$PROVIDERS_DIR"/*.json; do
        if [[ -f "$file" ]]; then
            providers+=("$file")
            names+=("$(jq -r '.name' "$file")")
        fi
    done

    if [[ ${#providers[@]} -eq 0 ]]; then
        echo -e "${RED}No providers found${NC}"
        exit 1
    fi

    echo -e "${BLUE}Select provider:${NC}"
    echo

    local current=$(get_current_provider)
    for i in "${!names[@]}"; do
        local marker=""
        if [[ "${names[$i]}" == "$current" ]]; then
            marker=" ${GREEN}*${NC}"
        fi
        printf "  ${YELLOW}%2d${NC}) %s%s\n" "$((i+1))" "${names[$i]}" "$marker"
    done
    echo

    read -p "Enter choice [1-${#names[@]}]: " choice

    if [[ "$choice" =~ ^[0-9]+$ ]] && [[ "$choice" -ge 1 ]] && [[ "$choice" -le ${#names[@]} ]]; then
        switch_provider "${names[$((choice-1))]}"
    else
        echo -e "${RED}Invalid choice${NC}"
        exit 1
    fi
}

# --- Completions ---

show_completions() {
    local shell="$1"
    case "$shell" in
        bash)
            cat <<'COMP'
# cc-switch bash completion
_cc_switch() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local prev="${COMP_WORDS[COMP_CWORD-1]}"
    local commands="status list help validate check rollback completions"
    local opts="-p --project -h --help -v --version"

    local script_dir
    script_dir="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"

    if [[ "$prev" == "-p" || "$prev" == "--project" ]]; then
        COMPREPLY=($(compgen -d -- "$cur"))
        return
    fi

    if [[ "$prev" == "completions" ]]; then
        COMPREPLY=($(compgen -W "bash zsh" -- "$cur"))
        return
    fi

    if [[ "$prev" == "check" ]]; then
        local providers=""
        for f in "$script_dir"/providers/*.json; do
            [[ -f "$f" ]] && providers+=" $(jq -r '.name' "$f")"
        done
        COMPREPLY=($(compgen -W "$providers" -- "$cur"))
        return
    fi

    local providers=""
    for f in "$script_dir"/providers/*.json; do
        [[ -f "$f" ]] && providers+=" $(jq -r '.name' "$f")"
    done

    COMPREPLY=($(compgen -W "$commands $opts $providers" -- "$cur"))
}
complete -F _cc_switch cc-switch
COMP
            ;;
        zsh)
            cat <<'COMP'
#compdef cc-switch
_cc-switch() {
    local -a commands providers
    commands=('status:Show active provider' 'list:List providers' 'help:Show help' \
              'validate:Validate provider configs' 'check:Health check providers' \
              'rollback:Undo last switch' 'completions:Generate shell completions')

    local script_dir="${0:A:h}"
    local -a provider_files
    provider_files=(${script_dir}/providers/*.json(N))
    providers=()
    for f in "${provider_files[@]}"; do
        providers+=("$(jq -r '.name' "$f")")
    done

    _arguments \
        '(-p --project)'{-p,--project}'[Target project settings]:project path:_directories' \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '1:command:(($commands $providers))' \
        '2:arg:->arg'

    case $words[2] in
        completions) _describe 'shell' '(bash zsh)' ;;
        check) _describe 'provider' providers ;;
    esac
}
_cc-switch "$@"
COMP
            ;;
        *)
            echo -e "${RED}Unsupported shell: $shell${NC}. Use: bash, zsh"
            exit 1
            ;;
    esac
}

# --- Help ---

show_help() {
    echo "cc-provider-switch v${VERSION} - Switch Claude Code API providers"
    echo
    echo "Usage:"
    echo "  cc-switch [opts]              Interactive menu"
    echo "  cc-switch [opts] <provider>   Switch to provider"
    echo "  cc-switch [opts] <command>    Run command"
    echo
    echo "Commands:"
    echo "  status        Show current provider"
    echo "  list          List all providers"
    echo "  validate      Validate all provider configs"
    echo "  check [name]  Health check provider(s)"
    echo "  rollback      Undo last switch"
    echo "  completions <bash|zsh>  Generate shell completions"
    echo "  help          Show this help"
    echo
    echo "Options:"
    echo "  -p, --project <path>   Target project settings"
    echo "  -v, --version          Show version"
    echo "  -h, --help             Show help"
    echo
    echo "Examples:"
    echo "  cc-switch ollama              Switch to Ollama"
    echo "  cc-switch -p ~/proj ollama    Switch project to Ollama"
    echo "  cc-switch check               Check all providers"
    echo "  cc-switch rollback            Undo last switch"
}

# --- Parse args ---

while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--project)
            if [[ -z "${2:-}" ]]; then
                echo -e "${RED}Error: --project requires a path${NC}" >&2
                exit 1
            fi
            PROJECT_PATH="$2"
            shift 2
            ;;
        -v|--version)
            echo "cc-provider-switch v${VERSION}"
            exit 0
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        -*)
            echo -e "${RED}Unknown option: $1${NC}" >&2
            show_help >&2
            exit 1
            ;;
        *)
            if [[ -z "$COMMAND" ]]; then
                COMMAND="$1"
            else
                COMMAND_ARG="$1"
            fi
            shift
            ;;
    esac
done

# Resolve settings file path
if [[ -n "$PROJECT_PATH" ]]; then
    if [[ -f "$PROJECT_PATH" && "$PROJECT_PATH" == *.json ]]; then
        SETTINGS_FILE="$PROJECT_PATH"
    else
        PROJECT_PATH="${PROJECT_PATH%/}"
        SETTINGS_FILE="$PROJECT_PATH/.claude/settings.local.json"
    fi
    BACKUP_FILE="${SETTINGS_FILE}.bak"

    if [[ ! -f "$SETTINGS_FILE" ]]; then
        mkdir -p "$(dirname "$SETTINGS_FILE")"
        echo '{}' > "$SETTINGS_FILE"
    fi
else
    BACKUP_FILE="${SETTINGS_FILE}.bak"
fi

# --- Main ---

init_config

case "$COMMAND" in
    "")
        interactive_menu
        ;;
    status|s)
        show_status
        ;;
    list|ls)
        list_providers
        ;;
    validate)
        validate_all_providers
        ;;
    check)
        if [[ -n "$COMMAND_ARG" ]]; then
            check_provider "$COMMAND_ARG"
        else
            check_all_providers
        fi
        ;;
    rollback)
        rollback_switch
        ;;
    completions)
        if [[ -z "$COMMAND_ARG" ]]; then
            echo -e "${RED}Usage: cc-switch completions <bash|zsh>${NC}" >&2
            exit 1
        fi
        show_completions "$COMMAND_ARG"
        ;;
    help)
        show_help
        ;;
    *)
        switch_provider "$COMMAND"
        ;;
esac
